---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Toolbar from '../components/Toolbar.astro';
import GradientShapes from '../components/GradientShapes.astro';
import { FaqAccordion } from '../components/FaqAccordion';
import { useTranslations } from '../data/translations';

const lang = 'en';
const t = useTranslations(lang);
---

<Layout title="Frequently Asked Questions - Fixed" lang={lang}>
  <!-- Background Gradient Elements -->
  <GradientShapes />

  <!-- Navbar Section -->
  <Toolbar slot="navbar" lang={lang} />

  <!-- FAQ Content -->
  <section class="flex w-full flex-col items-center justify-center py-16">
    <div class="mx-auto mb-12 w-full max-w-[700px] text-center">
      <h2 class="mb-6 text-5xl leading-tight font-extrabold text-white">
        {t.landing.faq.title}
      </h2>
      <p
        class="mx-auto max-w-[600px] text-base leading-relaxed text-zinc-300 max-sm:px-4"
      >
        {t.landing.faq.description}
      </p>
    </div>

    <!-- Faq Accordion Island -->
    <div class="w-full max-w-[800px] px-4">
      <FaqAccordion client:load lang={lang} />
    </div>
  </section>

  <!-- Footer Section -->
  <Footer slot="footer" lang={lang} />

  </Layout>
