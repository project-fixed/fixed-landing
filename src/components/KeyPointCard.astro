---
export interface Props {
  title: string;
  description: string;
  class?: string;
  style?: string;
}

const { title, description, class: className = '', style = '' } = Astro.props;
---

<div 
  class={`bg-gradient-to-br from-[#2c4350]/90 via-[#1e2f38]/90 to-[#152027]/90 flex flex-col gap-5 rounded-2xl border border-white/10 p-8 shadow-2xl backdrop-blur-md transition-all hover:border-[#3E5D6C]/50 hover:shadow-[#3E5D6C]/20 ${className}`} 
  style={style}
>
  <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-white/5 border border-white/10 text-[#9ec1d4]">
    <slot name="icon" />
  </div>
  
  <div class="flex flex-col gap-2">
    <span class="font-mono text-5xl font-black tracking-tighter text-white">
      {title}
    </span>
    <p class="text-sm font-medium leading-relaxed text-zinc-300">
      {description}
    </p>
  </div>
</div>
