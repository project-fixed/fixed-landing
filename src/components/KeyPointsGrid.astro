---
import { useTranslations, type Lang } from '../data/translations';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const topStats = [
  {
    title: t.landing.home.hero.key.point1.title, // "75K"
    description: t.landing.home.hero.key.point1.description,
  },
  {
    title: t.landing.home.hero.key.point2.title, // "92.5%"
    description: t.landing.home.hero.key.point2.description,
  },
  {
    title: t.landing.home.hero.key.point3.title, // "30+"
    description: t.landing.home.hero.key.point3.description,
  }
];

// Eliminamos point5 (100% historial) como pediste, para quedarnos con 2 tarjetas abajo
const bottomFeatures = [
  {
    title: t.landing.home.hero.key.point4.title, // "24/7"
    description: t.landing.home.hero.key.point4.description,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-6"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>`
  },
  {
    title: t.landing.home.hero.key.point6.title, // "Instant"
    description: t.landing.home.hero.key.point6.description,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-6"><path d="m13 2-2 10h9L9 22l2-10H3L13 2z"></path></svg>`
  }
];
---

<section class="page-section flex flex-col items-center justify-center py-16">
  <div class="w-full max-w-[1200px] flex flex-col gap-6">
    
    <!-- Top Stats Banner -->
    <div class="bg-primary/90 bg-gradient-to-br from-primary to-primary/80 shadow-2xl rounded-[24px] p-8 md:p-12 border border-white/10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-0 text-center divide-y md:divide-y-0 md:divide-x divide-white/20">
        {
          topStats.map((stat) => (
            <div class="flex flex-col items-center justify-center py-6 md:py-0">
              <h3 class="text-6xl md:text-7xl font-mono font-bold text-white mb-4 tracking-tight drop-shadow-sm">{stat.title}</h3>
              <p class="text-sm md:text-base text-white/90 max-w-[250px] mx-auto font-medium">{stat.description}</p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Bottom Features Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 min-h-[400px]">
      {
        bottomFeatures.map((feature) => (
          <div class="bg-zinc-900/60 border border-white/5 shadow-2xl rounded-[24px] p-8 md:p-12 flex flex-col items-start relative overflow-hidden group hover:border-white/10 transition-colors duration-300">
            <!-- Small Icon Box -->
            <div class="bg-zinc-800/80 p-3 rounded-xl mb-8 border border-white/5 text-zinc-300 shadow-inner z-10">
              <Fragment set:html={feature.icon} />
            </div>
            
            <!-- Content -->
            <h4 class="text-3xl md:text-4xl font-mono font-bold text-white mb-6 z-10 tracking-tight">{feature.title}</h4>
            <p class="text-lg text-zinc-400 leading-relaxed z-10 max-w-[90%]">{feature.description}</p>
            
            <!-- Abstract Background Graphic (Using scaled up icon for texture) -->
            <div class="absolute -bottom-20 -right-20 opacity-[0.03] pointer-events-none transition-transform duration-700 ease-out group-hover:scale-110 group-hover:rotate-6 [&>svg]:w-[350px] [&>svg]:h-[350px]">
              <Fragment set:html={feature.icon} />
            </div>
          </div>
        ))
      }
    </div>

  </div>
</section>
