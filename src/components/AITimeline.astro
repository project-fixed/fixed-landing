---
import { useTranslations, type Lang } from '../data/translations';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const data = t.landing.home.ai.process;

const steps = [
  {
    num: "01",
    title: data.step1.title,
    description: data.step1.description,
  },
  {
    num: "02",
    title: data.step2.title,
    description: data.step2.description,
  },
  {
    num: "03",
    title: data.step3.title,
    description: data.step3.description,
  },
  {
    num: "04",
    title: data.step4.title,
    description: data.step4.description,
  }
];
---

<section class="page-section py-24 relative overflow-hidden">
  <div class="w-full max-w-[1200px] mx-auto px-6">
    <div class="flex flex-col lg:flex-row gap-16 lg:gap-24">
      
      <!-- Left Side: Sticky Header -->
      <div class="w-full lg:w-5/12">
        <div class="sticky top-32">
          <h2 class="text-5xl md:text-6xl leading-[1.1] font-extrabold text-white mb-6 tracking-tight">
            {data.title}
          </h2>
          <p class="text-lg text-zinc-400 leading-relaxed max-w-[400px]">
            {data.description}
          </p>
        </div>
      </div>

      <!-- Right Side: Timeline Steps -->
      <div class="w-full lg:w-7/12 flex flex-col pt-4 lg:pt-0">
        {steps.map((step, index) => (
          <div class="relative flex flex-row gap-8 pb-16 lg:pb-24 group">
            
            <!-- Connector Line (hide on last item) -->
            {index !== steps.length - 1 && (
              <div class="absolute left-6 top-14 bottom-0 w-[1px] bg-gradient-to-b from-white/10 to-transparent lg:to-white/10"></div>
            )}
            
            <!-- Step Circle -->
            <div class="w-12 h-12 rounded-full border border-white/10 bg-zinc-950 flex items-center justify-center shrink-0 relative z-10 group-hover:border-primary/50 transition-colors duration-500 shadow-xl">
              <span class="font-mono text-xs text-zinc-500 group-hover:text-primary transition-colors">{step.num}</span>
            </div>

            <!-- Content -->
            <div class="flex flex-col gap-3 pt-2">
              <h3 class="text-2xl md:text-3xl font-mono font-bold text-white tracking-tight">{step.title}</h3>
              <p class="text-base md:text-lg text-zinc-400 leading-relaxed max-w-[500px]">
                {step.description}
              </p>
            </div>

          </div>
        ))}
      </div>

    </div>
  </div>
</section>
