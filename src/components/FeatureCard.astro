---
interface Props {
  title: string;
  description: string;
  image: string;
  step?: string;
}

const { title, description, image, step } = Astro.props;
---

<div
  class="group relative flex h-full min-h-[460px] flex-col overflow-hidden rounded-[24px] border border-white/5 bg-zinc-900/60 shadow-2xl transition-all duration-500 hover:-translate-y-2 hover:border-white/10 hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)]"
>
  {
    step && (
      <div class="absolute top-6 left-6 z-20 flex items-center justify-center rounded-xl border border-white/10 bg-zinc-950/60 px-4 py-2 backdrop-blur-md shadow-lg transition-transform duration-300 group-hover:scale-105">
        <span class="font-mono text-xs font-bold tracking-widest text-primary uppercase">
          STEP {step}
        </span>
      </div>
    )
  }

  <div class="relative h-[260px] w-full overflow-hidden shrink-0">
    <img
      class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-110 opacity-70 group-hover:opacity-100"
      src={image}
      alt={title}
      loading="lazy"
    />
    <!-- Smooth gradient fade into the card background -->
    <div class="absolute inset-0 bg-gradient-to-t from-zinc-900/90 via-zinc-900/30 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-zinc-900/80 to-transparent"></div>
  </div>

  <div class="flex flex-grow flex-col justify-end px-8 pb-10 pt-4 relative z-10 -mt-10">
    <h4 class="mb-4 text-2xl md:text-3xl font-mono font-bold text-white tracking-tight transition-colors group-hover:text-primary/90">{title}</h4>
    <p class="text-zinc-400 text-sm md:text-base leading-relaxed text-left">
      {description}
    </p>
  </div>
</div>
