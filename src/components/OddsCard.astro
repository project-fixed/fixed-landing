---
export interface Props {
  time: string;
  percent: string | number;
  odds: string | number;
  type: string;
  match: string;
  class?: string;
  style?: string;
}

const { time, percent, odds, type, match, class: className = '', style = '' } = Astro.props;

// Ensure percent has a '%' if it's a number
const formattedPercent = String(percent).includes('%') ? percent : `${percent}%`;
---

<div class={`bg-zinc-950/80 backdrop-blur-sm border border-white/10 rounded-2xl p-4 flex flex-col gap-4 hover:bg-zinc-900/80 transition-colors cursor-pointer ${className}`} style={style}>
  <div class="flex justify-between items-center">
    <div class="flex items-center gap-2">
      <svg class="w-4 h-4 text-zinc-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
      </svg>
      <span class="bg-zinc-800/80 text-white text-xs font-semibold px-2.5 py-1 rounded-lg">{time}</span>
      <span class="bg-zinc-800/80 text-white text-xs font-semibold px-2.5 py-1 rounded-lg">{formattedPercent}</span>
    </div>
    <span class="text-white text-sm font-medium">{odds}</span>
  </div>
  <div class="text-white text-sm font-semibold">
    {type}
  </div>
  <div class="flex justify-between items-center">
    <span class="text-zinc-400 text-xs">{match}</span>
    <svg class="w-4 h-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
    </svg>
  </div>
</div>
