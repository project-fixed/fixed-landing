---
import OddsCard from './OddsCard.astro';

const oddsData = [
  {
    delay: -5,
    time: "21:00",
    percent: "58.45%",
    odds: "1.85",
    type: "1X2: 1",
    match: "Real Madrid - Barcelona"
  },
  {
    delay: -4,
    time: "19:30",
    percent: "62.10%",
    odds: "2.10",
    type: "Over 2.5",
    match: "Arsenal - Chelsea"
  },
  {
    delay: -3,
    time: "20:45",
    percent: "55.20%",
    odds: "1.75",
    type: "BTTS: Yes",
    match: "Juventus - AC Milan"
  },
  {
    delay: -2,
    time: "16:30",
    percent: "80.15%",
    odds: "1.25",
    type: "Over 1.5",
    match: "Man City - Fulham"
  },
  {
    delay: -1,
    time: "17:00",
    percent: "50.50%",
    odds: "1.95",
    type: "1X2: 2",
    match: "Sevilla - Atl. Madrid"
  },
  {
    delay: 0,
    time: "20:00",
    percent: "65.30%",
    odds: "1.65",
    type: "Under 3.5",
    match: "Ajax - PSV"
  }
];
---

<div class="relative flex h-[450px] w-[450px] items-center justify-center max-md:h-[350px] max-md:w-[350px]">
  <!-- Rotative Cards -->
  {
    oddsData.map((item) => (
      <div 
        class="odds-card-animated pointer-events-none absolute z-10 w-[400px] opacity-0 max-[425px]:w-[320px] max-[375px]:w-[290px] lg:w-[350px]"
        style={`--delay: ${item.delay};`}
      >
        <OddsCard
          time={item.time}
          percent={item.percent}
          odds={item.odds}
          type={item.type}
          match={item.match}
          class="w-full shadow-2xl"
        />
      </div>
    ))
  }

  <!-- Glowing Background Circle -->
  <div class="pointer-events-none absolute h-[400px] w-[400px] rounded-full bg-[#3E5D6C]/5 blur-[120px] max-md:h-[250px] max-md:w-[250px] z-0"></div>
</div>

<style>
  @keyframes odds-float {
    0% {
      opacity: 0;
      transform: translate(-10%, -160%) scale(0.7);
    }

    20% {
      opacity: 0.5;
      transform: translate(-5%, -80%) scale(0.85);
    }

    40% {
      opacity: 1;
      pointer-events: auto;
      transform: translate(0, 0) scale(1);
    }

    60% {
      opacity: 0.5;
      transform: translate(40%, 80%) scale(0.85);
    }

    80% {
      opacity: 0;
      transform: translate(80%, 160%) scale(0.7);
    }

    100% {
      opacity: 0;
      transform: translate(80%, 160%) scale(0.7);
    }
  }

  .odds-card-animated {
    animation: odds-float 18s linear infinite;
    animation-delay: calc(3s * var(--delay));
  }
</style>
