---
import { useTranslations, type Lang } from '../data/translations';
import imgLogo from '../assets/images/logo.png';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Base paths for routes based on language
const homePath = lang === 'en' ? '/' : '/es';
const plansPath = lang === 'en' ? '/plans' : '/es/plans';
const faqPath = lang === 'en' ? '/faq' : '/es/faq';
const appAuthUrl = 'https://app.fixed.com/auth'; // Cross-domain redirection
---

<header id="main-toolbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 ease-in-out w-full pt-6 px-4">
  <div id="toolbar-container" class="mx-auto flex items-center justify-between transition-all duration-500 ease-in-out w-full max-w-[1200px] px-6 py-4 rounded-full border border-transparent bg-transparent">
    <!-- Logo -->
    <a href={homePath} class="logo flex cursor-pointer items-center select-none">
      <img src={imgLogo.src} alt="Logo" class="mr-2 size-9" />
      <span id="brand" class="text-2xl font-bold text-white max-[425px]:hidden">
        Fix<b class="text-primary font-semibold">ed</b>
      </span>
    </a>

    <!-- Menu Center (Desktop) -->
    <nav class="hidden items-center gap-6 lg:flex">
      <a href={homePath} class="hover:text-white text-zinc-300 font-medium tracking-wide transition-colors text-sm">
        {t.navbar.home}
      </a>
      <a href={`${homePath}#features`} class="hover:text-white text-zinc-300 font-medium tracking-wide transition-colors text-sm">
        {t.navbar.features}
      </a>
      <a href={`${homePath}#about`} class="hover:text-white text-zinc-300 font-medium tracking-wide transition-colors text-sm">
        {t.navbar.about}
      </a>
      <a href={plansPath} class="hover:text-white text-zinc-300 font-medium tracking-wide transition-colors text-sm">
        {t.navbar.plans}
      </a>
      <a href={faqPath} class="hover:text-white text-zinc-300 font-medium tracking-wide transition-colors text-sm">
        {t.navbar.faq}
      </a>
    </nav>

    <!-- Right Side: Button & Mobile Menu -->
    <div class="flex items-center gap-4">
      <a href={`${appAuthUrl}?lang=${lang}`} class="btn bg-white text-black hover:bg-zinc-200 rounded-full px-6 py-2.5 text-center text-sm font-bold tracking-wider transition-all duration-300 hidden lg:block">
        {t.button.join}
      </a>
      
      <!-- Mobile Bars Button -->
      <button
        id="btn-mobile-menu-open"
        class="rounded border border-white/10 bg-white/5 p-2 text-white transition-colors duration-200 hover:bg-white/10 active:scale-95 lg:hidden"
        aria-label="Open menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M12 17.25h8.25"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Drawer Overlay -->
  <div
    id="mobile-menu-overlay"
    class="fixed inset-0 z-[99] hidden bg-black/60 opacity-0 backdrop-blur-sm transition-opacity duration-300"
  >
  </div>

  <!-- Mobile Drawer Menu -->
  <div
    id="mobile-menu-drawer"
    class="bg-main-800 fixed inset-y-0 right-0 z-[100] flex w-72 max-w-[80vw] translate-x-full transform flex-col gap-8 border-l border-white/5 p-8 shadow-2xl transition-transform duration-300 ease-in-out"
  >
    <div class="flex items-center justify-between">
      <span class="text-xl font-bold text-white">Menu</span>
      <button
        id="btn-mobile-menu-close"
        class="rounded bg-white/5 p-2 text-white hover:bg-white/10"
        aria-label="Close menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <nav class="flex flex-col gap-6 text-left text-lg font-bold">
      <a href={homePath} class="hover:text-primary text-zinc-100 transition-colors mobile-link">{t.navbar.home}</a>
      <a href={`${homePath}#features`} class="hover:text-primary mobile-link text-zinc-100 transition-colors">{t.navbar.features}</a>
      <a href={`${homePath}#about`} class="hover:text-primary mobile-link text-zinc-100 transition-colors">{t.navbar.about}</a>
      <a href={plansPath} class="hover:text-primary text-zinc-100 transition-colors mobile-link">{t.navbar.plans}</a>
      <a href={faqPath} class="hover:text-primary text-zinc-100 transition-colors mobile-link">{t.navbar.faq}</a>
    </nav>

    <div class="mt-auto flex flex-col gap-4">
      <a href={`${appAuthUrl}?lang=${lang}`} class="btn bg-white text-black hover:bg-zinc-200 block w-full rounded-full py-3 text-center font-bold tracking-wider">
        {t.button.join}
      </a>
    </div>
  </div>
</header>

<script>
  // Scroll behaviour for the unified toolbar
  const toolbarHeader = document.getElementById('main-toolbar');
  const toolbarContainer = document.getElementById('toolbar-container');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      toolbarHeader?.classList.replace('pt-6', 'pt-4');
      toolbarContainer?.classList.add('bg-[#131111]/85', 'backdrop-blur-xl', 'border-white/[0.06]', 'shadow-[0_20px_50px_rgba(0,0,0,0.5)]');
      toolbarContainer?.classList.remove('border-transparent', 'bg-transparent');
    } else {
      toolbarHeader?.classList.replace('pt-4', 'pt-6');
      toolbarContainer?.classList.remove('bg-[#131111]/85', 'backdrop-blur-xl', 'border-white/[0.06]', 'shadow-[0_20px_50px_rgba(0,0,0,0.5)]');
      toolbarContainer?.classList.add('border-transparent', 'bg-transparent');
    }
  });

  // Mobile menu logic
  const openBtn = document.getElementById('btn-mobile-menu-open');
  const closeBtn = document.getElementById('btn-mobile-menu-close');
  const drawer = document.getElementById('mobile-menu-drawer');
  const overlay = document.getElementById('mobile-menu-overlay');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  function openMenu() {
    if (drawer && overlay) {
      overlay.classList.remove('hidden');
      requestAnimationFrame(() => {
        overlay.classList.add('opacity-100');
        drawer.classList.remove('translate-x-full');
      });
      document.body.style.overflow = 'hidden';
    }
  }

  function closeMenu() {
    if (drawer && overlay) {
      drawer.classList.add('translate-x-full');
      overlay.classList.remove('opacity-100');
      setTimeout(() => {
        overlay.classList.add('hidden');
      }, 300);
      document.body.style.overflow = '';
    }
  }

  if (openBtn) openBtn.addEventListener('click', openMenu);
  if (closeBtn) closeBtn.addEventListener('click', closeMenu);
  if (overlay) overlay.addEventListener('click', closeMenu);

  mobileLinks.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
