---
import { useTranslations, type Lang } from '../data/translations';
import imgLogo from '../assets/images/logo.png';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const homePath = lang === 'en' ? '/' : '/es';
const plansPath = lang === 'en' ? '/plans' : '/es/plans';
const faqPath = lang === 'en' ? '/faq' : '/es/faq';
---

<footer
  class="footer relative z-20 mt-20 overflow-hidden border-t border-white/10 pt-16 pb-8 text-zinc-100"
>
  <!-- Gradient Footer Blobs -->
  <div
    class="pointer-events-none absolute -bottom-[100px] left-0 z-[-1] h-full w-full scale-x-[-1] scale-y-[-1] max-[1250px]:-bottom-[175px] max-sm:-bottom-[100px]"
  >
    <div
      class="bg-landing-effect-1 blob-animated fixed -top-[250px] -left-[100px] z-[-1] h-[600px] w-[400px] -rotate-5 rounded-full opacity-10 blur-[120px]"
    >
    </div>
    <div
      class="bg-landing-effect-2 blob-animated fixed -top-[250px] left-[300px] z-[-1] h-[550px] w-[600px] rotate-[125deg] rounded-full opacity-10 blur-[120px]"
    >
    </div>
    <div
      class="bg-landing-effect-3 blob-animated fixed top-[50px] left-[650px] z-[-1] h-[250px] w-[350px] rotate-[110deg] rounded-full opacity-10 blur-[120px]"
    >
    </div>
    <div
      class="bg-landing-effect-6 blob-animated fixed -top-[300px] left-[1000px] z-[-1] h-[600px] w-[800px] rotate-[-75deg] rounded-full opacity-10 blur-[120px]"
    >
    </div>
    <div
      class="bg-landing-effect-6 blob-animated fixed -top-[150px] left-[1350px] z-[-1] h-[500px] w-[700px] rotate-0 rounded-full opacity-10 blur-[120px]"
    >
    </div>
  </div>

  <div class="container mx-auto px-4">
    <div class="mb-12 flex flex-wrap items-start justify-between gap-12">
      <!-- Brand -->
      <div class="flex max-w-sm flex-col">
        <img src={imgLogo.src} alt="Fixed Logo" class="mb-4 size-11" />
        <span class="mb-2 text-2xl font-bold text-white"
          >{t.landing.footer.title}</span
        >
        <p class="text-sm leading-relaxed text-zinc-300">
          {t.landing.footer.description}
        </p>
      </div>

      <!-- Menus -->
      <div class="flex flex-wrap gap-20 max-md:gap-8">
        <!-- Links Product -->
        <div class="flex flex-col gap-4 text-left">
          <span class="text-xs font-bold tracking-wider text-white uppercase"
            >{t.landing.footer.link.dimensions.product}</span
          >
          <a
            href={`${homePath}#features`}
            class="hover:text-primary text-sm text-zinc-300 transition-all duration-300"
            >{t.navbar.features}</a
          >
          <a
            href={`${homePath}#steps`}
            class="hover:text-primary text-sm text-zinc-300 transition-all duration-300"
            >{t.navbar.steps}</a
          >
          <a
            href={`${homePath}#about`}
            class="hover:text-primary text-sm text-zinc-300 transition-all duration-300"
            >{t.navbar.about}</a
          >
        </div>

        <!-- Links More -->
        <div class="flex flex-col gap-4 text-left">
          <span class="text-xs font-bold tracking-wider text-white uppercase"
            >{t.landing.footer.link.dimensions.more}</span
          >
          <a
            href={plansPath}
            class="hover:text-primary text-sm text-zinc-300 transition-all duration-300"
            >{t.navbar.plans}</a
          >
          <a
            href={faqPath}
            class="hover:text-primary text-sm text-zinc-300 transition-all duration-300"
            >{t.navbar.faq}</a
          >
        </div>
      </div>
    </div>

    <hr class="my-8 border-white/10" />

    <!-- Legal -->
    <div
      class="flex flex-wrap items-center justify-between gap-4 text-sm text-zinc-400"
    >
      <p>&copy; {new Date().getFullYear()} Fixed Inc. All rights reserved.</p>
      <div class="flex flex-wrap gap-8 max-md:gap-4">
        <a href="#" class="hover:text-primary transition-colors duration-300"
          >{t.landing.footer.link.company.termsOfService}</a
        >
        <a href="#" class="hover:text-primary transition-colors duration-300"
          >{t.landing.footer.link.company.privacyPolicy}</a
        >
        <a href="#" class="hover:text-primary transition-colors duration-300"
          >{t.landing.footer.link.company.cookies}</a
        >
      </div>
    </div>
  </div>
</footer>

<style>
  @keyframes slider-shape {
    0%,
    100% {
      opacity: 0.15;
      border-radius: 42% 58% 70% 30% / 45% 45% 55% 55%;
      transform: translate3d(0, 0, 0) rotateZ(0.01deg);
    }
    35% {
      opacity: 0.1;
      border-radius: 70% 30% 46% 54% / 30% 29% 71% 70%;
      transform: translate3d(0, 5px, 0) rotateZ(0.01deg);
    }
    50% {
      opacity: 0.05;
      transform: translate3d(0, 0, 0) rotateZ(0.01deg);
    }
    65% {
      opacity: 0.1;
      border-radius: 100% 60% 60% 100% / 100% 100% 60% 60%;
      transform: translate3d(0, -3px, 0) rotateZ(0.01deg);
    }
  }

  .blob-animated {
    animation: slider-shape 5s linear infinite;
  }
</style>
