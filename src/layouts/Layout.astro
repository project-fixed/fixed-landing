---
import '../styles/global.css';
import TranslateButton from '../components/TranslateButton.astro';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const {
  title,
  description = 'Fixed - Your ultimate dashboard',
  lang = 'en',
} = Astro.props;
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {lang === 'en' && (
      <script is:inline>
        if (!document.cookie.includes('language=en')) {
          const isSpanish = navigator.language.startsWith('es') || document.cookie.includes('language=es');
          if (isSpanish) {
            const path = window.location.pathname;
            if (!path.startsWith('/es')) {
              window.location.pathname = ('/es' + path).replace(/\/$/, '');
            }
          }
        }
      </script>
    )}
  </head>
  <body>
    <!-- Gradient Shapes background element (Will be ported in Phase 2) -->
    <div
      id="gradient-shapes-container"
      class="pointer-events-none absolute inset-0 z-0 overflow-hidden"
    >
      <!-- Slots for background visuals -->
    </div>

    <div class="relative z-10 container mx-auto flex min-h-screen flex-col p-8">
      <!-- Navbar (Will be ported in Phase 2) -->
      <slot name="navbar" />

      <main class="flex-grow">
        <slot />
      </main>

      <!-- Footer (Will be ported in Phase 2) -->
      <slot name="footer" />
    </div>

    <!-- Sticky Floating Navigation Toolbar -->
    <slot name="toolbar" />

    <!-- Translate Button (Fixed bottom-right corner) -->
    <TranslateButton lang={lang as 'en' | 'es'} class="fixed bottom-0 right-0 z-[100] rounded-none rounded-tl-xl border-r-0 border-b-0" />
  </body>
</html>
